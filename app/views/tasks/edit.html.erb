<h1>Edit <%= @task.title %></h1>
<%= form_with model: @task do |f| %>
  <%= f.label :title %>
  <%= f.text_field :title %>
  <%= f.label :details %>
  <%= f.text_field :details %>
  <%= f.label :completed %>
  <%= f.checkbox :completed %>
  <%= f.submit %>
<% end %>
<%= link_to @task.title, task_path(@task) %>
